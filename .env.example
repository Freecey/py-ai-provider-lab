# Copy this file to .env and fill in your API keys.
# The app reads these at startup to auto-fill credential forms and seed default credentials.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Alibaba DashScope (International) ─────────────────────────────────────────
DASHSCOPE_API_KEY=sk-...

# ── MiniMax ───────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ── Z.ai (GLM) ────────────────────────────────────────────────────────────────
# Format: {API_Key_ID}.{secret}
ZAI_API_KEY=

# ── App settings (optional) ───────────────────────────────────────────────────
# APP_DATA_DIR=./data
# APP_LOG_LEVEL=INFO
# APP_LANG=fr
# APP_THEME=light
# APP_CRYPTO_PASSPHRASE=change-me-in-production
